{
	"$schema": "https://code.claude.com/schemas/plugin.json",
	"name": "vicky",
	"version": "0.5.2",
	"description": "Demand-driven knowledge base. Auto-enriches answers when gaps detected. Drives Obsidian + Dataview for live KB views.",
	"author": {
		"name": "sayhe",
		"url": "https://github.com/yesitsfebreeze"
	},
	"license": "MIT",
	"homepage": "https://github.com/yesitsfebreeze/vicky#readme",
	"repository": "https://github.com/yesitsfebreeze/vicky",
	"keywords": [
		"knowledge-base",
		"research",
		"dataview",
		"obsidian",
		"demand-driven",
		"gap-detection"
	],
	"mcpServers": {
		"vicky": {
			"command": "node",
			"args": [
				"${CLAUDE_PLUGIN_ROOT}/dist/vicky.js"
			],
			"description": "Vicky: demand-driven knowledge base"
		}
	}
}
